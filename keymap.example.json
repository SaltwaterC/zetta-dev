[
  {
    "context": "Zetta > Terminal",
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-shift-t": "zetta::NewTab",
      "ctrl-shift-n": "zetta::NewWindow",
      "ctrl-shift-w": "zetta::CloseTab",
      "alt-shift-d": "zetta::DetachTab",
      "alt-shift-a": "zetta::ReconnectSession",
      "ctrl-shift-o": "zetta::SplitHorizontal",
      "ctrl-shift-e": "zetta::SplitVertical",
      "alt-shift-o": ["zetta::ApplyPaneSplitTemplate", { "name": "three-right" }],
      "alt-shift-e": ["zetta::ApplyPaneSplitTemplate", { "name": "quarters" }],
      "ctrl-shift-a": "terminal_view::SelectAll",
      "ctrl-shift-backspace": "terminal_view::ClearClipboard",
      "alt-left": "zetta::FocusPaneLeft",
      "alt-right": "zetta::FocusPaneRight",
      "alt-up": "zetta::FocusPaneUp",
      "alt-down": "zetta::FocusPaneDown",
      "shift-escape": "zetta::ToggleMaximizePane",
      "alt-shift-down": "zetta::MinimizePane",
      "alt-shift-up": "zetta::RestoreMinimizedPane",
      "alt-shift-left": "zetta::SelectPreviousMinimizedPane",
      "alt-shift-right": "zetta::SelectNextMinimizedPane",
      "ctrl-shift-i": "zetta::ToggleBroadcastInput",
      "ctrl-tab": "zetta::NextTab",
      "ctrl-shift-tab": "zetta::PreviousTab",
      "ctrl-pageup": "zetta::NextTab",
      "ctrl-pagedown": "zetta::PreviousTab",
      "ctrl-v": "terminal::Paste",
      "ctrl-shift-f": "terminal_view::SearchScrollback",
      "ctrl-alt-f": "zetta::SearchTabScrollback",
      "ctrl-alt-v": "terminal::PasteTrimmed",
      "ctrl-shift-s": "zetta::SavePaneOutput",
      "ctrl-shift-p": "zetta::ToggleCommandPalette",
      "ctrl-,": "zetta::ToggleSettings",
      "ctrl-shift-d": "zetta::ToggleSerialConsole",
      "ctrl-alt-r": "zetta::RenameTab",
      "alt-shift-l": "zetta::RenamePane",
      "ctrl-=": "zetta::IncreaseTerminalFontSize",
      "ctrl--": "zetta::DecreaseTerminalFontSize",
      "ctrl-0": "zetta::ResetTerminalFontSize",
      "ctrl-alt-=": "zetta::IncreasePaneFontSize",
      "ctrl-alt--": "zetta::DecreasePaneFontSize",
      "ctrl-alt-0": "zetta::ResetPaneFontSize",
      "ctrl-shift-r": "zetta::ReloadConfiguration",
      "ctrl-shift-f12": "zetta::TogglePerformanceOverlay",
      "ctrl-!": ["zetta::OpenProfile", { "slot": 1 }],
      "ctrl-@": ["zetta::OpenProfile", { "slot": 2 }],
      "ctrl-#": ["zetta::OpenProfile", { "slot": 3 }],
      "ctrl-$": ["zetta::OpenProfile", { "slot": 4 }],
      "ctrl-%": ["zetta::OpenProfile", { "slot": 5 }],
      "ctrl-^": ["zetta::OpenProfile", { "slot": 6 }],
      "ctrl-&": ["zetta::OpenProfile", { "slot": 7 }],
      "ctrl-*": ["zetta::OpenProfile", { "slot": 8 }],
      "ctrl-(": ["zetta::OpenProfile", { "slot": 9 }]
    }
  },
  {
    "context": "Zetta > Terminal && screen == normal",
    "bindings": {
      "pageup": "terminal::ScrollPageUp",
      "pagedown": "terminal::ScrollPageDown"
    }
  },
  {
    "context": "Zetta > Terminal && selection",
    "bindings": {
      "ctrl-c": "terminal_view::CopyAndClearSelection"
    }
  },
  {
    "context": "Zetta > Terminal && scrollback_search",
    "bindings": {
      "enter": "terminal_view::SearchNextMatch",
      "shift-enter": "terminal_view::SearchPreviousMatch",
      "f3": "terminal_view::SearchNextMatch",
      "shift-f3": "terminal_view::SearchPreviousMatch",
      "escape": "terminal_view::DismissSearch",
      "ctrl-a": "terminal_view::SelectAllSearchText"
    }
  }
]
